# ─── Supabase / Postgres ───────────────────────────────────────
# Get this from Supabase → Settings → Database → Connection string (URI)
# Use the "Transaction" pooler (port 6543) for serverless/Vercel
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres

# ─── Supabase Client (for future auth) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Platform API Keys (Phase 3) ──────────────────────────────
# Get from console.cloud.google.com → enable "Places API (New)" → create API key
GOOGLE_PLACES_API_KEY=
# Get from yelp.com/developers → create app → copy API key
YELP_API_KEY=
