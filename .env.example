# ─── Supabase / Postgres ───────────────────────────────────────
# Get this from Supabase → Settings → Database → Connection string (URI)
# Use the "Transaction" pooler (port 6543) for serverless/Vercel
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres

# ─── Supabase Client (for future auth) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Platform API Keys ───────────────────────────────────────
# Get from console.cloud.google.com → enable "Places API (New)" → create API key
GOOGLE_PLACES_API_KEY=
# Get from developers.facebook.com → create app → Graph API Explorer → Page Access Token
FACEBOOK_ACCESS_TOKEN=
# Get from developer.foursquare.com → create project → copy API key
FOURSQUARE_API_KEY=

# ─── Ad Provider ────────────────────────────────────────────
# Which ad network to use: "adsense" | "medianet" | "ezoic" | "carbon" | "infolinks" | "none"
NEXT_PUBLIC_AD_PROVIDER=none

# ─── Google AdSense (optional) ──────────────────────────────
# Get from google.com/adsense → your publisher ID (ca-pub-XXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# ─── Media.net (optional) ───────────────────────────────────
# Get from media.net → sign up → customer ID from dashboard
NEXT_PUBLIC_MEDIANET_CUSTOMER_ID=
NEXT_PUBLIC_MEDIANET_WIDGET_ID=

# ─── Ezoic (optional) ──────────────────────────────────────
# Get from ezoic.com → sign up → site ID from dashboard
NEXT_PUBLIC_EZOIC_SITE_ID=

# ─── Carbon Ads (optional) ─────────────────────────────────
# Get from carbonads.net → sign up → serve ID and placement
NEXT_PUBLIC_CARBON_SERVE_ID=
NEXT_PUBLIC_CARBON_PLACEMENT=

# ─── Infolinks (optional) ────────────────────────────────
# Get from infolinks.com → sign up → PID from dashboard
NEXT_PUBLIC_INFOLINKS_PID=

# ─── Cloudflare Turnstile (spam protection) ──────────────────
# Get from dash.cloudflare.com → Turnstile → Add site → copy keys
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
